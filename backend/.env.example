NODE_ENV="development"

# MongoDB Connection (Local Development)
# For production, use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI="mongodb://localhost:27017/hospital_db"

# Better Auth Configuration
BETTER_AUTH_SECRET="change-me-to-a-random-string-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:5000"
FRONTEND_URL="http://localhost:5173"

# Optional: AI Services
GEMINI_KEY=""

# Optional: File Upload
UPLOADTHING_TOKEN=""

# Optional: Billing (Polar)
POLAR_PRODUCT_ID=""
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""

# Server Port
PORT=5000
